{
  "name": "@dan8oren/mcp-apple-notes",
  "version": "1.0.2",
  "author": "",
  "type": "module",
  "main": "index.ts",
  "description": "MCP server for semantic search and RAG over Apple Notes",
  "mcpName": "io.github.Dan8Oren/mcp-apple-notes",
  "keywords": [
    "mcp",
    "apple-notes",
    "semantic-search",
    "rag",
    "jxa"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Dan8Oren/mcp-apple-notes"
  },
  "license": "ISC",
  "bin": {
    "mcp-apple-notes": "./bin/apple-notes-mcp.js"
  },
  "files": [
    "index.ts",
    "bin"
  ],
  "scripts": {
    "build": "bun build index.ts --outdir dist --target node",
    "start": "bun index.ts",
    "purge-db": "rm -rf ~/.mcp-apple-notes",
    "test": "for f in test/test-search.mjs test/test-resolver.mjs; do npx tsx \"$f\" 2>&1 | grep -q '0 failed' || exit 1; done; for f in test/test-*.mjs; do case \"$f\" in test/test-search.mjs|test/test-resolver.mjs) continue;; esac; node --experimental-vm-modules \"$f\" || exit 1; done"
  },
  "exports": {
    ".": "./index.ts"
  },
  "dependencies": {
    "@huggingface/transformers": "3.1.2",
    "@lancedb/lancedb": "0.14.0",
    "@langchain/textsplitters": "0.1.0",
    "@modelcontextprotocol/sdk": "1.0.3",
    "marked": "18.0.0",
    "run-jxa": "3.0.0",
    "tsx": "4.21.0",
    "turndown": "7.2.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/turndown": "5.0.5",
    "prettier": "3.8.1",
    "typescript": "6.0.2"
  }
}
